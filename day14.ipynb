    "\n",
    "# 1. 데이터베이스 통로 생성\n",
    "conn = sqlite3.connect(\"member.db\")\n",
    "# 2. SQL 통로 생성\n",
    "curs = conn.cursor()\n",
    "# 3. CRUD\n",
    "# 막간 Tip : SQL문에서 문자열과 날짜는 반드시 ''로 감싼다\n",
    "# DB 하나의 작업단위 트랜잭션 transaction\n",
    "# 하나의 작업이 끝나면 반드시 반영! / 되돌려지거나!\n",
    "# 반영 : commit / 되돌려진다 : rollback => 이전 트랜잭션 상태로 되돌린다\n",
    "sql = \"\"\"\n",
    "INSERT INTO user\n",
    "VALUES ('sungwoo', '1234', '공성우', '30')\n",
    "\"\"\"\n",
    "\n",
    "curs.execute(sql)\n",
    "conn.commit()   # C, U, D 작업을 하면 커밋을 하자\n",
    "# 4. 통로 닫기 (역순으로 닫자)\n",
    "curs.close()\n",
    "conn.close()"
