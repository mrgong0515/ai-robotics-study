    "url += \"&units=metric\"\n",
    "\n",
    "import requests # get 방식으로 요청할 때 사용하는 라이브러리\n",
    "response = requests.get(url)\n",
    "\n",
    "# 3가지 방법으로 처리\n",
    "# 1) text : response.text\n",
    "# 2) byte : response.content\n",
    "# 3) json : response.json()\n",
    "\n",
    "result = response.json()"
   ]
