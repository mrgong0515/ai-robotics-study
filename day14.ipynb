    "# 날씨 정보를 요청해서 csv로 저장하는 코드\n",
    "import requests\n",
    "import csv\n",
    "from datetime import datetime\n",
    "import os\n",
    "\n",
    "# API KEY\n",
    "MY_API_KEY = \"694565175bd20955427f75192522ae76\"\n",
    "\n",
    "city_name = \"Seoul\"\n",
    "\n",
    "url = f\"https://api.openweathermap.org/data/2.5/weather?q={city_name}&appid={MY_API_KEY}&units=metric\"\n",
    "\n",
    "response = requests.get(url)\n",
    "result = response.json()\n",
    "\n",
    "main = result[\"weather\"][0][\"main\"]       # 날씨 상태\n",
    "temp = result[\"main\"][\"temp\"]             # 현재 온도\n",
    "humidity = result[\"main\"][\"humidity\"]     # 습도\n",
    "current_time = datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n",
    "\n",
    "# csv 파일 존재 여부 확인\n",
    "csv_exist = os.path.exists(\"weather.csv\")\n",
    "\n",
    "header = [\"current_time\", \"temp\", \"humidity\", \"main\"]\n",
    "\n",
    "with open(\"weather.csv\", \"a\", newline=\"\") as f:\n",
    "    writer = csv.writer(f)\n",
    "\n",
    "    if not csv_exist:\n",
    "        writer.writerow(header)\n",
    "\n",
    "    writer.writerow([current_time, temp, humidity, main])\n",
    "\n",
    "print(\"날씨 저장 완료\")"
   ]
  },
